		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"concurrently": "^9.2.1",
		"husky": "^9.1.7",
		"jsdom": "^27.4.0",
		"lint-staged": "^16.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^3.2.4",
		"web-vitals": "^5.1.0"
	},
	"lint-staged": {
		"*": [
			"biome check --write"
		]
