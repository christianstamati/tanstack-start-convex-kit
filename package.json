{
	"name": "tanstack-start-convex-kit",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently -k \"bun dev:convex\" \"bun dev:frontend\"",
		"dev:frontend": "vite dev --port 3000",
		"dev:convex": "bun convex dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"lint": "biome check",
		"format": "biome format --write .",
		"check": "biome check",
		"typecheck": "tsc --noEmit",
		"machine-translate": "inlang machine translate --project project.inlang",
		"prepare": "husky"
	},
	"dependencies": {
		"@auth/core": "0.37.0",
		"@base-ui/react": "^1.3.0",
